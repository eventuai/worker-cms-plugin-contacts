<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Contacts</h1>
    <p class="mt-1 text-sm text-gray-500">{{ total }} contact{% if total != 1 %}s{% endif %}{% if q != blank %} matching “{{ q | escape }}”{% endif %}</p>
  </div>
  <div class="flex flex-wrap gap-2">
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ importHref | escape }}">Import</a>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ exportHref | escape }}">Export CSV</a>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700" href="{{ createHref | escape }}">New contact</a>
  </div>
</div>

<form method="get" action="{{ searchAction | escape }}" class="flex flex-wrap items-center gap-1.5 mb-4">
  <input class="block px-3 py-2 border border-gray-300 rounded-lg text-sm flex-1" type="search" name="q" value="{{ q | escape }}" placeholder="Search name, email, organization, phone…">
  <button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer" type="submit">Search</button>
  {% if q != blank %}<a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-gray-300 bg-white text-gray-700 hover:bg-gray-50" href="{{ searchAction | escape }}">Clear</a>{% endif %}
</form>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
  <table class="w-full text-left text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Organization</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Phone</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Region</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      {% for row in rows %}
      <tr>
        <td class="px-6 py-3 text-sm text-gray-700"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ row.editHref | escape }}">{{ row.name | escape }}</a>{% if row.title != blank %}<div class="text-xs text-gray-400">{{ row.title | escape }}</div>{% endif %}</td>
        <td class="px-6 py-3 text-sm text-gray-700">{{ row.organization | escape }}</td>
        <td class="px-6 py-3 text-sm text-gray-700">{{ row.email | escape }}{% if row.emailStatus != blank %} <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">{{ row.emailStatus | escape }}</span>{% endif %}</td>
        <td class="px-6 py-3 text-sm text-gray-700">{{ row.phone | escape }}</td>
        <td class="px-6 py-3 text-sm text-gray-700">{{ row.region | escape }}</td>
        <td class="px-6 py-3 text-right"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ row.editHref | escape }}">Edit</a></td>
      </tr>
      {% else %}
      <tr><td colspan="6" class="px-6 py-10 text-center text-sm text-gray-400">{% if q != blank %}No contacts match this search.{% else %}No contacts yet — create or import some.{% endif %}</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>

{% if hasPrev or hasNext %}
<div class="flex items-center justify-between gap-4 mb-4" style="margin-top:1rem">
  <div>{% if hasPrev %}<a class="text-indigo-600 font-medium hover:text-indigo-800 text-sm" href="{{ prevHref | escape }}">← Previous</a>{% endif %}</div>
  <div class="text-sm text-gray-500">Showing {{ offset | plus: 1 }}–{{ offset | plus: count }} of {{ total }}</div>
  <div>{% if hasNext %}<a class="text-indigo-600 font-medium hover:text-indigo-800 text-sm" href="{{ nextHref | escape }}">Next →</a>{% endif %}</div>
</div>
{% endif %}
