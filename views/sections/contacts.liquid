<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Contacts</h1>
    <p class="mt-1 text-sm text-gray-500">{{ total }} contact{% if total != 1 %}s{% endif %}{% if q != blank %} matching “{{ q }}”{% endif %}</p>
  </div>
  <div class="flex flex-wrap gap-2">
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ importHref }}">Import</a>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ exportHref }}">Export CSV</a>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700" href="{{ createHref }}">New contact</a>
  </div>
</div>

{% if flash != blank %}
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="margin-bottom:1rem">
  <p class="text-sm text-gray-700">{{ flash | t }}</p>
</div>
{% endif %}

<form method="get" action="{{ searchAction }}" class="flex flex-wrap items-center gap-1.5 mb-4">
  <input class="block px-3 py-2 border border-gray-300 rounded-lg text-sm flex-1" type="search" name="q" value="{{ q }}" placeholder="Search name, email, organization, phone…">
  <button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer" type="submit">Search</button>
  {% if q != blank %}<a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-gray-300 bg-white text-gray-700 hover:bg-gray-50" href="{{ searchAction }}">Clear</a>{% endif %}
</form>

{% if canEdit and count > 0 %}
<form id="contacts-bulk-form" method="post" action="{{ bulkDeleteAction }}" data-confirm="Delete the selected contacts?" class="flex flex-wrap items-center justify-between gap-4 mb-4 bg-white rounded-xl shadow-sm border border-gray-200 p-3">
  {% if q != blank %}<input type="hidden" name="q" value="{{ q }}">{% endif %}
  <div class="text-sm text-gray-500"><span data-bulk-count>0</span> selected</div>
  <button type="submit" data-bulk-submit class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-red-600 text-white hover:bg-red-700 cursor-pointer">Delete selected</button>
</form>
{% endif %}

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
  <table class="w-full min-w-[680px] text-left text-sm" data-privacy-table>
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        {% if canEdit %}<th class="w-12 px-6 py-3">
          {% if count > 0 %}<input type="checkbox" data-bulk-select-all hidden title="Select all listed contacts" aria-label="Select all listed contacts" class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">{% endif %}
        </th>{% endif %}
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Organization</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Phone</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Region</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      {% for row in rows %}
      <tr>
        {% if canEdit %}<td class="px-6 py-3"><input type="checkbox" name="ids" value="{{ row.id }}" form="contacts-bulk-form" data-bulk-checkbox aria-label="Select {{ row.name }}" class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500"></td>{% endif %}
        <td class="px-6 py-3 text-sm text-gray-700"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ row.editHref }}" data-private-field="name">{{ row.name }}</a>{% if row.title != blank %}<div class="text-xs text-gray-400">{{ row.title }}</div>{% endif %}</td>
        <td class="px-6 py-3 text-sm text-gray-700">{{ row.organization }}</td>
        <td class="px-6 py-3 text-sm text-gray-700"><span data-private-field="email">{{ row.email }}</span>{% if row.emailStatus != blank %} <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">{{ row.emailStatus }}</span>{% endif %}</td>
        <td class="px-6 py-3 text-sm text-gray-700"><span data-private-field="phone">{{ row.phone }}</span></td>
        <td class="px-6 py-3 text-sm text-gray-700">{{ row.region }}</td>
        <td class="px-6 py-3 text-right"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ row.editHref }}">Edit</a></td>
      </tr>
      {% else %}
      <tr data-table-filter-empty><td colspan="{% if canEdit %}7{% else %}6{% endif %}" class="px-6 py-10 text-center text-sm text-gray-400">{% if q != blank %}No contacts match this search.{% else %}No contacts yet — create or import some.{% endif %}</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>

{% if hasPrev or hasNext %}
<div class="flex items-center justify-between gap-4 mb-4" style="margin-top:1rem">
  <div>{% if hasPrev %}<a class="text-indigo-600 font-medium hover:text-indigo-800 text-sm" href="{{ prevHref }}">← Previous</a>{% endif %}</div>
  <div class="text-sm text-gray-500">Showing {{ offset | plus: 1 }}–{{ offset | plus: count }} of {{ total }}</div>
  <div>{% if hasNext %}<a class="text-indigo-600 font-medium hover:text-indigo-800 text-sm" href="{{ nextHref }}">Next →</a>{% endif %}</div>
</div>
{% endif %}

{% if canEdit %}<script src="/admin/plugins/contacts/assets/contacts-bulk.js" defer></script>{% endif %}
