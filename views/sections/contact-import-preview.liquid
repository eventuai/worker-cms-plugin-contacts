<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref | escape }}">← Import</a>
    <h1 class="text-2xl font-bold text-gray-900">Import preview</h1>
    <p class="mt-1 text-sm text-gray-500">{{ newCount }} new · {{ updateCount }} updated · {{ unchangedCount }} unchanged. Nothing has been written yet.</p>
  </div>
</div>

<form method="post" action="{{ confirmAction | escape }}" class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="margin-bottom:1rem">
  <input type="hidden" name="raw" value="{{ raw | escape }}">
  <div class="flex flex-wrap items-center gap-1.5">
    <label class="block">
      <span class="block text-sm text-gray-700 mb-1">Apply</span>
      <select class="block px-3 py-2 border border-gray-300 rounded-lg text-sm" name="mode">
        <option value="new_and_update">New + updates</option>
        <option value="new_only">New contacts only</option>
        <option value="update_only">Updates only</option>
      </select>
    </label>
    <button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer" type="submit" style="margin-top:1.25rem">Apply import</button>
  </div>
</form>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
  <table class="w-full text-left text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Organization</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Changes</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      {% for row in rows %}
      <tr>
        <td class="px-6 py-3 text-sm text-gray-700">
          {% if row.isNew %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700">new</span>
          {% elsif row.isUpdate %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-indigo-100 text-indigo-700">update</span>
          {% else %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">unchanged</span>{% endif %}
        </td>
        <td class="px-6 py-3 text-sm text-gray-700">{{ row.name | escape }}</td>
        <td class="px-6 py-3 text-sm text-gray-700">{{ row.email | escape }}</td>
        <td class="px-6 py-3 text-sm text-gray-700">{{ row.organization | escape }}</td>
        <td class="px-6 py-3 text-sm text-gray-700">
          {% if row.hasChanges %}
            {% for change in row.changes %}
            <div class="text-xs"><span class="font-semibold">{{ change.label | escape }}:</span> {% if change.from != blank %}{{ change.from | escape }} → {% endif %}{{ change.to | escape }}</div>
            {% endfor %}
          {% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
